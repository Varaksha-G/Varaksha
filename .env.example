# Varaksha Fraud Detection System - Environment Variables

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND (Next.js / Cloudflare Pages)
# ═══════════════════════════════════════════════════════════════════════════════

# Optional: Backend API URL (for Cloudflare Pages environment variables)
# If not set, the frontend will auto-detect based on hostname at runtime:
# - varaksha.pages.dev → https://varaksha-production.up.railway.app
# - localhost → http://localhost:8000
#
# Setting this env var in Cloudflare Pages provides a backup fallback.
# Go to: Settings > Environment Variables > Add NEXT_PUBLIC_API_URL
#
NEXT_PUBLIC_API_URL=https://varaksha-production.up.railway.app

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND (Python Sidecar / Rust Gateway)
# ═══════════════════════════════════════════════════════════════════════════════

# Sidecar service URL (used by Rust gateway to call Python ML inference)
# In Docker Compose: http://sidecar:8001/score
# In Railway: Service-to-service communication
SIDECAR_URL=http://127.0.0.1:8001/score

# Port for Rust gateway (default: 8082 for Railway, 8000 for local)
PORT=8000

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

# Rust logging level (debug, info, warn, error)
RUST_LOG=info

# Python logging level
LOG_LEVEL=INFO
